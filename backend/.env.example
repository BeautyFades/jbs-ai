# --- LLM backend: "claude" (default) | "gemini" | "openai" | "local" ---
# Can also be overridden per-request from the frontend's provider dropdown.
LLM_PROVIDER=claude

# --- Claude ---
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Gemini (Google AI Studio key: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro
# To use Vertex AI instead of AI Studio, set these instead of GEMINI_API_KEY:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# --- OpenAI, or any OpenAI-compatible cloud endpoint (Groq, Together, ...) ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=  # leave unset for api.openai.com

# --- Local model server (OpenAI-compatible API) ---
# Defaults target Ollama (`ollama serve`, then `ollama pull llama3.1`).
# For LM Studio use http://localhost:1234/v1; for vLLM/llama.cpp point at
# whatever port they serve the OpenAI-compatible API on.
LOCAL_MODEL=llama3.1
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama

# --- Operational database (PostgreSQL) ---
# `docker compose up db` provides this locally. Override per environment.
DATABASE_URL=postgresql+asyncpg://jbs:jbs@localhost:5432/jbs_ai
# Create tables from ORM metadata on startup (dev). Set false where Alembic
# migrations own the schema.
DB_CREATE_ALL=true

# --- MCP mode: "mock" (default, DuckDB-backed local servers) or "real" ---
MCP_MODE=mock

# --- Real mode: dbt MCP (https://github.com/dbt-labs/dbt-mcp) ---
# Launched as: uvx dbt-mcp
DBT_HOST=cloud.getdbt.com
DBT_PROD_ENV_ID=
DBT_TOKEN=
DBT_PROJECT_DIR=
DBT_PATH=dbt

# --- Real mode: Snowflake MCP (https://github.com/Snowflake-Labs/mcp) ---
# Launched as: uvx snowflake-labs-mcp --service-config-file $SNOWFLAKE_MCP_CONFIG --connection-name $SNOWFLAKE_CONNECTION_NAME
SNOWFLAKE_MCP_CONFIG=./snowflake_mcp_config.yaml
SNOWFLAKE_CONNECTION_NAME=default
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
